  "groups": {
    "default": {
      "name": "default",
      "systemPrompt": {
        "text": "You are a helpful, concise, and accurate assistant."
      },
      "models": [
        {
          "provider": "openai",
          "modelId": "o3-mini",
          "enabled": true
        },
        {
          "provider": "anthropic",
          "modelId": "claude-3-7-sonnet-20250219",
          "enabled": true
        },
        {
          "provider": "google",
          "modelId": "gemini-2.5-pro-exp-03-25",
          "enabled": true
        }
      ],
      "description": "Default model group"
    },
    "fast": {
      "name": "fast",
      "systemPrompt": {
        "text": "You are an assistant that provides quick, concise responses. Prioritize brevity and efficiency in your answers."
      },
      "models": [
        {
          "provider": "openai",
          "modelId": "o3-mini",
          "enabled": true
        }
      ],
      "description": "Fastest models for quick responses"
    },
    "thinking": {
      "name": "thinking",
      "systemPrompt": {
        "text": "You are a careful, methodical assistant that thinks through problems step-by-step. Provide your thinking process in a structured, logical manner."
      },
      "models": [
        {
          "provider": "anthropic",
          "modelId": "claude-3-7-sonnet-20250219",
          "enabled": true,
          "options": {
            "temperature": 1,
            "maxTokens": 20000,
            "thinking": {
              "type": "enabled",
              "budget_tokens": 16000
            }
          }
        }

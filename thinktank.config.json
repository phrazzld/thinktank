{
  "models": [
    {
      "provider": "openai",
      "modelId": "gpt-4o",
      "enabled": true,
      "options": {
        "temperature": 0.7,
        "maxTokens": 5000
      }
    },
    {
      "provider": "openai",
      "modelId": "o3-mini",
      "enabled": true,
      "options": {
        "maxTokens": 5000
      }
    },
    {
      "provider": "anthropic",
      "modelId": "claude-3-7-sonnet-20250219",
      "enabled": true,
      "options": {
        "temperature": 1,
        "maxTokens": 20000,
        "thinking": {
          "type": "enabled",
          "budget_tokens": 16000
        }
      }
    },
    {
      "provider": "google",
      "modelId": "gemini-2.5-pro-exp-03-25",
      "enabled": true,
      "options": {
        "temperature": 0.7,
        "maxTokens": 5000
      }
    },
    {
      "provider": "openrouter",
      "modelId": "deepseek/deepseek-r1",
      "enabled": true,
      "apiKeyEnvVar": "OPENROUTER_API_KEY",
      "options": {
        "temperature": 0.7,
        "maxTokens": 5000
      }
    },
    {
      "provider": "openrouter",
      "modelId": "deepseek/deepseek-chat-v3-0324",
      "enabled": true,
      "apiKeyEnvVar": "OPENROUTER_API_KEY",
      "options": {
        "temperature": 0.7,
        "maxTokens": 5000
      }
    }

      "description": "Claude with thinking capability enabled"
    },
    "deepseek": {
      "name": "deepseek",
      "systemPrompt": {
        "text": "You are DeepSeek, a helpful and knowledgeable AI assistant. Provide accurate, relevant, and insightful information."
      },
      "models": [
        {
          "provider": "openrouter",
          "modelId": "deepseek/deepseek-r1",
          "enabled": true
        },
        {
          "provider": "openrouter",
          "modelId": "deepseek/deepseek-chat-v3-0324",
          "enabled": true
        }
      ],
      "description": "DeepSeek models via OpenRouter"

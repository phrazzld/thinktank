{
  "name": "thinktank",
  "version": "0.1.0",
  "description": "A CLI tool for querying multiple LLMs with the same prompt",
  "main": "dist/runtime/cli.js",
  "bin": {
    "thinktank": "dist/runtime/cli.js"
  },
  "type": "commonjs",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/runtime/cli.ts",
    "start": "node dist/runtime/cli.js",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "jest",
    "test:cov": "jest --coverage",
    "prepare": "npm run build",
    "prepublishOnly": "npm test && npm run lint",
    "test:install": "npm pack && npm install -g thinktank-*.tgz && thinktank --version"
  },
  "files": [
    "dist",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "axios": "^1.6.0",
    "chalk": "^4.1.2",
    "dotenv": "^16.3.1",
    "openai": "^4.0.0",
    "ora": "^5.4.1",
    "yargs": "^17.7.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/jest": "^29.5.8",
    "@types/node": "^20.8.0",
    "@types/yargs": "^17.0.32",
    "@typescript-eslint/eslint-plugin": "^6.11.0",
    "@typescript-eslint/parser": "^6.11.0",
    "eslint": "^8.53.0",
    "eslint-config-prettier": "^9.0.0",
    "execa": "^5.1.1",
    "jest": "^29.7.0",
    "prettier": "^3.0.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.0"
  },
  "keywords": [
    "llm",
    "ai",
    "cli",
    "openai",
    "anthropic"
  ],
  "author": "Phaedrus Raznikov",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/phrazzld/thinktank"
  },
  "bugs": {
    "url": "https://github.com/phrazzld/thinktank/issues"
  },
  "homepage": "https://github.com/phrazzld/thinktank#readme"
}
